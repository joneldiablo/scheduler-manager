# ============================================
# THE ALCHEMIST - Environment Configuration
# ============================================
# REQUIRED: Superuser credentials (NO default values)
SUPERUSER_USER=admin
SUPERUSER_PASS=your-super-secret-password

# Server
HOST=0.0.0.0
PORT=3000

# API
API_PATH_PREFIX=/api

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h

# Frontend
ENABLE_FRONTEND=true

# Database
DATA_ROOT=./data
SQLITE_FILENAME=db.sqlite

# Planner (Gear A) - cron expression for buffer planning
PLANNER_CRON=*/5 * * * *

# Seed demo data on first run
SEED_ON_BOOTSTRAP=true
